1) Расчёт MAU авторов

SELECT main_author_name,
       COUNT(DISTINCT puid) as "mau"
FROM bookmate.audition ba
JOIN bookmate.content bc ON ba.main_content_id = bc.main_content_id
JOIN bookmate.author bat ON bc.main_author_id = bat.main_author_id
WHERE CAST(msk_business_dt_str AS timestamp) >= '2024-11-01' 
  AND msk_business_dt_str::timestamp < '2024-12-01'
GROUP BY main_author_name
ORDER BY mau DESC
LiMIT 3;

2) Расчёт MAU произведений

SELECT main_content_name,
       published_topic_title_list,
       main_author_name,
       COUNT(DISTINCT puid) as "mau"
FROM bookmate.audition ba
JOIN bookmate.content bc ON ba.main_content_id = bc.main_content_id
JOIN bookmate.author bat ON bc.main_author_id = bat.main_author_id
WHERE CAST(msk_business_dt_str AS timestamp) >= '2024-11-01' 
  AND msk_business_dt_str::timestamp < '2024-12-01'
GROUP BY main_content_name, main_author_name, published_topic_title_list
ORDER BY mau DESC
